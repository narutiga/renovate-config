{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":timezone(Asia/Tokyo)",
    "schedule:earlyMondays",
    "group:allNonMajor",
    "security:minimumReleaseAgeNpm",
    ":automergeMinor"
  ],
  "platformAutomerge": false,
  "prConcurrentLimit": 5,
  "lockFileMaintenance": {
    "enabled": true,
    "extends": ["schedule:monthly"],
    "automerge": true
  },
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "0.x versions can break in minor updates — merge manually",
      "matchCurrentVersion": "/^0\\./",
      "automerge": false
    },
    {
      "description": "Major updates always get manual review",
      "matchUpdateTypes": ["major"],
      "labels": ["major-update"]
    }
  ]
}
